      "cefrLevel": "",
      "idiomUsageNote": "",
      "englishDefinition": "",
      "patternPractice": [
        {
          "chinese": "他昨晚喝得太多，结果在浴室里剧烈呕吐。",
          "english": "He drank too much last night and ended up vomiting violently in the bathroom."
        },
        {
          "chinese": "食物中毒后，她开始剧烈呕吐，不得不去医院。",
          "english": "After food poisoning, she started vomiting violently and had to go to the hospital."
        },
        {
          "chinese": "晕船让他剧烈呕吐，整个人都虚脱了。",
          "english": "Seasickness made him vomit violently, leaving him completely exhausted."
